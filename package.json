{
  "name": "signal-swarm",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @signal-swarm/shared && npm run build --workspace @signal-swarm/agents && npm run build --workspace @signal-swarm/orchestrator && npm run build --workspace signal-swarm-dashboard",
    "demo": "tsx packages/agents/src/cli.ts ETH/USDC",
    "dev": "tsx packages/agents/src/cli.ts",
    "dev:dashboard": "npm run dev --workspace signal-swarm-dashboard",
    "dev:orchestrator": "npm run dev --workspace @signal-swarm/orchestrator",
    "test": "npm run test --workspace @signal-swarm/shared && npm run test --workspace @signal-swarm/agents && npm run test --workspace @signal-swarm/orchestrator",
    "typecheck": "tsc -b --force --pretty false",
    "preview:dashboard": "npm run preview --workspace signal-swarm-dashboard",
    "compile:contract": "npx tsx scripts/compile-contract.ts",
    "deploy:registry": "npx tsx scripts/deploy-registry.ts",
    "gen:wallets": "npx tsx scripts/gen-wallets.ts"
  },
  "dependencies": {
    "ethers": "^6.16.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.6",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@types/node": "^22.15.3",
    "dotenv": "^17.3.1",
    "hardhat": "^3.2.0",
    "solc": "^0.8.20",
    "vitest": "^4.1.0"
  }
}
